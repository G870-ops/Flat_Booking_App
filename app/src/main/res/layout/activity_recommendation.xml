<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F8F9FA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI Recommendations"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Based on your budget and commute preferences"
        android:textSize="14sp"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvNoMatch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No perfect match found. Try adjusting your filters."
        android:gravity="center"
        android:visibility="gone"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardRecommendation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvBestMatchTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Property Name"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1565C0"/>

            <TextView
                android:id="@+id/tvBestMatchPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Price: $0"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvBestMatchCommute"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Commute: 0 mins"
                android:layout_marginTop="4dp"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View This Match"
                android:layout_marginTop="16dp"
                android:backgroundTint="#4CAF50"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>